# =============================================================
# Neon PostgreSQL (from Vercel Dashboard → Storage → Neon)
# =============================================================

# 连接池 URL（用于 Prisma 查询，带 ?pgbouncer=true&connect_timeout=15）
# 格式：postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=15
POSTGRES_PRISMA_URL=

# 直连 URL（用于 prisma migrate，不带连接池参数）
# 格式：postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=

# =============================================================
# Admin account credentials (used by prisma/seed.ts)
# =============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# =============================================================
# NextAuth.js
# 生成 NEXTAUTH_SECRET：运行 openssl rand -base64 32
# =============================================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# =============================================================
# MinIO 对象存储（用于题目图片上传）
# =============================================================

# MinIO 服务器地址（不含协议前缀）
# 示例：117.72.47.130
MINIO_ENDPOINT=

# MinIO 服务器端口
# 示例：9000
MINIO_PORT=9000

# MinIO 访问密钥（Access Key）
MINIO_ACCESS_KEY=

# MinIO 私有密钥（Secret Key）
MINIO_SECRET_KEY=

# 默认存储桶名称
# 示例：exam-images
MINIO_BUCKET=exam-images

# 是否启用 SSL（true 或 false，默认 true）
MINIO_USE_SSL=true
